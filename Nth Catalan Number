class Solution {
    public static int solve(int n,int[] dp){
        int sum=0;
        if(n==0 || n==1) return 1;
        else if(dp[n]!=-1) return dp[n];
        else{
            for(int i=0;i<n;i++){
                sum+=solve(i,dp)*solve(n-i-1,dp);
            }
        }
        return dp[n]=sum;
    }
    public static int findCatalan(int n) {
        int[] dp=new int[n+1];
        Arrays.fill(dp,-1);
        return solve(n,dp);
    }
}
